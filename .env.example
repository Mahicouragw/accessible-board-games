# Database - Cloud Storage for Multiplayer & Saves
# Get from Neon: https://console.neon.tech → Project → Connection String
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# Neon API Key for Versioning/Branching (Optional, for scripts/neon-branch.js)
# Get from: https://console.neon.tech/app/settings/api-keys → Create API Key
NEON_API_KEY=napi_xxx
NEON_PROJECT_ID=proj_xxx

# GitHub Token for Edit/Delete Only accessible-board-games Repo (Optional, for scripts/github-edit.js)
# Create fine-grained PAT: https://github.com/settings/tokens?type=beta
# Only select repositories: Mahicouragw/accessible-board-games, Permissions: Contents Read and Write
GITHUB_TOKEN=github_pat_xxx

# App Config
NEXT_PUBLIC_APP_NAME=Accessible Board Games
NEXT_PUBLIC_VERCEL_URL=https://accessible-board-games.vercel.app
