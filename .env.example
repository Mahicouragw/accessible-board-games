# For local single-player mode, you can leave DATABASE_URL empty - build will succeed
# For full multiplayer, auth, rooms, chat, voice features, set DATABASE_URL

# Example for Neon / Vercel Postgres:
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Example local:
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# Next.js public env (optional)
NEXT_PUBLIC_APP_NAME=Accessible Board Games
